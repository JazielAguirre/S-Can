# ── Dependencias ──────────────────────────────────────────────
node_modules/
backend/node_modules/
ai/node_modules/

# ── Entorno virtual Python ────────────────────────────────────
venv/
ai/venv/
.venv/

# ── Cache Python ──────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# ── Modelos ML (archivos binarios pesados, ≥ 10 MB) ──────────
*.h5
*.keras
*.onnx
*.tflite
*.pb
*.pt
*.pth
saved_model/

# ── Dataset (imágenes, no van al repositorio) ─────────────────
ai/dataset/raw/*
!ai/dataset/raw/.gitkeep

ai/dataset/processed/*
!ai/dataset/processed/.gitkeep

ai/dataset_source/

# ── Uploads temporales del servidor ───────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Variables de entorno y configuración local ────────────────
.env
.env.local
.env.*.local
.env.production

# ── Herramientas de desarrollo local ─────────────────────────
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ── Sistema operativo ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pip-log.txt

# ── Build / distribución ──────────────────────────────────────
dist/
build/
